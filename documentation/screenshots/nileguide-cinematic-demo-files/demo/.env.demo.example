# NileGuide cinematic full demo credentials
# PowerShell usage:
# $env:DEMO_USER_EMAIL='tourist@example.com'
# $env:DEMO_USER_PASSWORD='TouristPassword123'
# $env:DEMO_ADMIN_EMAIL='admin@example.com'
# $env:DEMO_ADMIN_PASSWORD='AdminPassword123'

DEMO_USER_EMAIL=tourist@example.com
DEMO_USER_PASSWORD=TouristPassword123
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=AdminPassword123

# Optional
DEMO_BASE_URL=http://127.0.0.1:4200
DEMO_START_SERVER=true
DEMO_HEADLESS=false
DEMO_SLOW_MO=220
DEMO_PAUSE_MS=900
DEMO_SEARCH_TERM=pyramid
DEMO_PLAN_DATE=2026-06-28
DEMO_PLAN_TIME=10:00
DEMO_PLAN_PERIOD=AM
